{
  "name": "react-spa-with-hyper-express",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "react-router dev",
    "dev:backend": "cd backend && npx tsx index.ts",
    "refresh": "rm -f backend/database.sqlite && echo 'Database deleted. Restart backend to re-migrate.'",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "hyper-express": "^6.17.3",
    "isbot": "^5.1.36",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0",
    "reflect-metadata": "^0.2.2",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
